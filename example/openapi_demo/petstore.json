{
  "openapi": "3.0.0",
  "info": { "title": "Petstore API", "version": "1.0.0" },
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id":       { "type": "integer" },
          "name":     { "type": "string" },
          "tag":      { "type": "string" },
          "category": { "$ref": "#/components/schemas/Category" }
        }
      },
      "Category": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "id":   { "type": "integer" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
