{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "S-Expression",
  "scopeName": "source.sexp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#macro-keywords" },
    { "include": "#numbers" },
    { "include": "#symbols" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.semicolon.sexp",
      "match": ";.*$"
    },
    "strings": {
      "name": "string.quoted.double.sexp",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.sexp", "match": "\\\\." }
      ]
    },
    "macro-keywords": {
      "name": "keyword.control.macro.sexp",
      "match": "\\b(defrecord|defunion|defenum|defn|defFromJsonSchema|defFromOpenApi|defAllFromJsonSchema|unless|when|swap!|assertThat|withRetry|do|let|set!|if|return|throw)\\b"
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.sexp",   "match": "-?[0-9]+\\.[0-9]+" },
        { "name": "constant.numeric.integer.sexp", "match": "-?[0-9]+" },
        { "name": "constant.language.sexp",        "match": "\\b(true|false|null)\\b" }
      ]
    },
    "symbols": {
      "name": "variable.other.sexp",
      "match": "[a-zA-Z_!?+\\-*/<>=][a-zA-Z0-9_!?+\\-*/<>=.]*"
    }
  }
}
